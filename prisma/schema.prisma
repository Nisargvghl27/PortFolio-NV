generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  techStack   String[]
  githubLink  String?
  liveLink    String?
  imageUrl    String?
  projectType String   @default("other")
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Certificate {
  id        String   @id @default(uuid())
  title     String
  issuer    String
  date      String
  url       String
  desc      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Skill {
  id       String   @id @default(uuid())
  name     String
  category String
  color    String
  level    String
  latency  String
  status   String
  desc     String
  order    Int      @default(0)
}

model Message {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  isReplied Boolean  @default(false)
  createdAt DateTime @default(now())
}

