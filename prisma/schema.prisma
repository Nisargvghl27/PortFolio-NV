generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  techStack   String[]
  githubLink  String?
  liveLink    String?
  imageUrl    String?
  projectType String   @default("other")
  featured    Boolean  @default(false)
  
  // NEW impact metrics fields
  impactUsers    String?
  impactUptime   String?
  impactScore    String?
  impactStars    String?
  order          Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Certificate {
  id        String   @id @default(uuid())
  title     String
  issuer    String
  date      String
  url       String
  desc      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Skill {
  id       String @id @default(uuid())
  name     String
  category String
  color    String
  level    String
  latency  String
  status   String
  desc     String
  order    Int    @default(0)
}

model Message {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  isReplied Boolean  @default(false)
  createdAt DateTime @default(now())
}

// NEW model for site settings (open to work badge, resume URL, visitor count)
model SiteConfig {
  id            String  @id @default("singleton")
  openToWork    Boolean @default(true)
  openToWorkMsg String  @default("AVAILABLE_FOR_INTERNSHIP")
  resumeUrl     String  @default("https://drive.google.com/file/d/1AJ-d8MkJ6JpmOlhDuiNdKl2j0TPmHBmc/view?usp=sharing")
  visitorCount  Int     @default(0)
}